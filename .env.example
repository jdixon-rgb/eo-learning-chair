# Copy to .env.local and fill in values for your environment.
# .env.local is gitignored; this file (.env.example) is committed.
#
# Two environments are wired in this app:
#   - production : main branch, deploys via Vercel main, points at prod Supabase
#   - staging    : staging branch, deploys via Vercel preview, points at staging Supabase
#
# For local dev, point at whichever environment you intend to test against.
# When in doubt, point at staging.

# Which environment this build represents. One of: production | staging | development
# Drives Sentry environment tagging and any env-conditional UI.
VITE_APP_ENV=development

# Supabase — fill with the URL + anon key for the matching environment.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Sentry — leave blank to disable error reporting locally.
# In Vercel, set per-environment so production and staging report to the same
# Sentry project but with distinct `environment` tags.
VITE_SENTRY_DSN=
